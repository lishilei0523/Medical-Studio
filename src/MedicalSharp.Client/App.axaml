<Application x:Class="MedicalSharp.Client.App"
			 xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:fa="clr-namespace:FluentAvalonia.Styling;assembly=FluentAvalonia"
			 RequestedThemeVariant="Dark">

	<Application.Styles>
		<fa:FluentAvaloniaTheme />
		<StyleInclude Source="avares://IconPacks.Avalonia.MaterialDesign/MaterialDesign.axaml" />
		<StyleInclude Source="avares://SD.Infrastructure.Avalonia/Themes/Styles.axaml" />
		<StyleInclude Source="/Content/Dictionaries/Styles.Controls.axaml" />
		<StyleInclude Source="/Content/Dictionaries/Styles.DataGrid.axaml" />
		<StyleInclude Source="/Content/Dictionaries/Styles.Fluent.axaml" />
		<StyleInclude Source="/Content/Dictionaries/Styles.Form.axaml" />
	</Application.Styles>
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://SD.Infrastructure.Avalonia/Themes/Resources.axaml" />
				<ResourceInclude Source="/Content/Dictionaries/Resources.Brushes.axaml" />
				<ResourceInclude Source="/Content/Dictionaries/Resources.Converters.axaml" />
				<ResourceInclude Source="/Content/Dictionaries/Resources.Fluent.axaml" />
				<ResourceInclude Source="/Content/Dictionaries/Resources.Fonts.axaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Application.Resources>
</Application>
