<fa:AppWindow x:Class="MedicalSharp.Client.Views.HomeContext.IndexView"
			  xmlns="https://github.com/avaloniaui"
			  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			  xmlns:fa="clr-namespace:FluentAvalonia.UI.Windowing;assembly=FluentAvalonia"
			  xmlns:sd="https://github.com/lishilei0523/SD.Framework"
			  xmlns:cm="http://caliburnmicro.com"
			  mc:Ignorable="d"
			  Title="Medical Studio"
			  Width="1440" Height="900"
			  WindowStartupLocation="CenterScreen">

	<sd:BusyMask IsBusy="{Binding IsBusy}">
		<Grid>
			<Grid.RowDefinitions>
				<!--Header-->
				<RowDefinition Height="Auto" />
				<!--Body-->
				<RowDefinition Height="*" />
				<!--Footer-->
				<RowDefinition Height="25" />
			</Grid.RowDefinitions>
			<Grid Grid.Row="0">
				<Menu>
					<MenuItem Header="文件(_F)">
						<MenuItem Header="打开(_O)" Command="{Binding OpenSeriesCommand}" />
						<MenuItem Header="关闭(_C)" cm:Message.Attach="CloseSeries()" />
						<MenuItem Header="保存(_S)" cm:Message.Attach="SaveImage()" />
						<MenuItem Header="另存为(_A)" cm:Message.Attach="SaveAsImage()" />
					</MenuItem>
				</Menu>
			</Grid>
			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="240" />
					<ColumnDefinition />
					<ColumnDefinition />
					<ColumnDefinition Width="240" />
				</Grid.ColumnDefinitions>
				<sd:GroupBox Grid.Column="0" Header="患者" Margin="4,0,2,4"></sd:GroupBox>
				<sd:GroupBox Grid.Column="1" Header="体积渲染" Margin="2,0,2,4">
					<sd:VolumeViewport Background="Black"
									   Camera="{Binding OrbitCamera}"
									   VolumeData="{Binding VolumeData}"
									   TFControlPoints="{Binding TFControlPoints}">

					</sd:VolumeViewport>
				</sd:GroupBox>
				<Grid Grid.Column="2" Margin="2,0,2,4">
					<Grid.RowDefinitions>
						<RowDefinition />
						<RowDefinition />
						<RowDefinition />
					</Grid.RowDefinitions>
					<sd:GroupBox Grid.Row="0" Header="MPR-横断位" Margin="0,0,0,2">
						<sd:MPRViewport Background="Black"
										Camera="{Binding AxialCamera}"
										VolumeData="{Binding VolumeData}">

						</sd:MPRViewport>
					</sd:GroupBox>
					<sd:GroupBox Grid.Row="1" Header="MPR-冠状位" Margin="0,2,0,2">
						<sd:MPRViewport Background="Black"
										Camera="{Binding CoronalCamera}"
										VolumeData="{Binding VolumeData}">

						</sd:MPRViewport>
					</sd:GroupBox>
					<sd:GroupBox Grid.Row="2" Header="MPR-矢状位" Margin="0,2,0,0">
						<sd:MPRViewport Background="Black"
										Camera="{Binding SagittalCamera}"
										VolumeData="{Binding VolumeData}">

						</sd:MPRViewport>
					</sd:GroupBox>
				</Grid>
				<sd:GroupBox Grid.Column="3" Header="患者" Margin="2,0,4,4"></sd:GroupBox>
			</Grid>
			<Grid Grid.Row="2" Background="Green">

			</Grid>
		</Grid>
	</sd:BusyMask>
</fa:AppWindow>
