<UserControl x:Class="MedicalSharp.Client.Views.VolumeContext.MprSagittalView"
			 xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:cm="http://caliburnmicro.com"
			 xmlns:sd="https://github.com/lishilei0523/SD.Framework"
			 mc:Ignorable="d">

    <sd:MPRViewport Background="Black"
                    Camera="{Binding SagittalCamera}"
                    VolumeData="{Binding VolumeData}">

    </sd:MPRViewport>
</UserControl>
