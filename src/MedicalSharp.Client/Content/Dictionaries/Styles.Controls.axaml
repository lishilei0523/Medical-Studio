<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--Window默认样式-->
  <Style Selector="Window">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontFamily" Value="/Content/Fonts/msyh.ttf#Microsoft YaHei"/>
  </Style>
  <!--UserControl默认样式-->
  <Style Selector="UserControl">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontFamily" Value="/Content/Fonts/msyh.ttf#Microsoft YaHei"/>
  </Style>
  <!--TextBlock默认样式-->
  <Style Selector="TextBlock">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontFamily" Value="/Content/Fonts/msyh.ttf#Microsoft YaHei"/>
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <!--TextBlock超链接样式-->
  <Style Selector="TextBlock.Hyperlink">
    <Setter Property="Foreground" Value="#0094FF" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="Cursor" Value="Hand" />
    <Style Selector="^:pointerover">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#0094FF" />
    </Style>
  </Style>
  <!--TextBlock行内样式-->
  <Style Selector="TextBlock.Inline">
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="10,0,0,0" />
  </Style>
  <!--TextBlock时间样式-->
  <Style Selector="TextBlock.DateTime">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <!--TextBox默认样式-->
  <Style Selector="TextBox">
    <Setter Property="MinWidth" Value="210" />
    <Setter Property="FontFamily" Value="/Content/Fonts/msyh.ttf#Microsoft YaHei"/>
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <!--ComboBox默认样式-->
  <Style Selector="ComboBox">
    <Setter Property="FontFamily" Value="/Content/Fonts/msyh.ttf#Microsoft YaHei"/>
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <!--Button默认样式-->
  <Style Selector="Button">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontFamily" Value="/Content/Fonts/msyh.ttf#Microsoft YaHei"/>
    <Setter Property="Width" Value="85" />
    <Setter Property="Height" Value="32" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="1" />
    <Setter Property="Margin" Value="10,0,0,0" />
    <Setter Property="BorderBrush" Value="#898989" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <!--Button焦点样式-->
  <Style Selector="Button.Focus">
    <Setter Property="BorderBrush" Value="#43339C" />
  </Style>
  <!--Button圆角样式-->
  <Style Selector="Button.Flat" >
    <Setter Property="BorderBrush" Value="#43339C" />
    <Setter Property="Width" Value="85" />
    <Setter Property="Height" Value="28" />
    <Setter Property="Margin" Value="0,5,10,0" />
    <Setter Property="Padding" Value="4" />
  </Style>
</Styles>
